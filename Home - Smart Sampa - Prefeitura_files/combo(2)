(function () {
  document.addEventListener("DOMContentLoaded", () => {
    const scriptUrl =
      "https://storage.googleapis.com/liferaycloud-cdn-product-experience-manager-assets-prd/script/liferay-product-experience-manager.umd.min.js";

    const script = document.createElement("script");

    script.type = "text/javascript";
    script.async = true;
    script.src = scriptUrl;

    document.body.appendChild(script);
  });
})();

(function () {
    console.debug("✅ Script de Gerenciamento de Conteúdo Liferay carregado!");

    // Configuração de domínios genéricos para demonstração
    const dominiosOrigem = ['https://www.prefeitura.sp.gov.br', 'https://www2.prefeitura.sp.gov.br'];
    const dominioDestino = 'https://prefeitura.sp.gov.br';
    const journalPortletId = 'com_liferay_journal_web_portlet_JournalPortlet';

    function ajustarUrlsNoticias() {
        // Validação de contexto: Verifica se o p_p_id na URL é o do Journal (Web Content)
        const urlPagina = new URL(window.location.href);
        if (urlPagina.searchParams.get('p_p_id') !== journalPortletId) return;

        // Seletor baseado na estrutura do Clay UI (dropdown do Liferay)
        const seletor = 'a.dropdown-item[role="menuitem"][href*="/w/"]';
        const links = document.querySelectorAll(seletor);

        links.forEach(link => {
            // Se o elemento já possui o marcador de correção, ignora para evitar substituições em cascata
            if (link.dataset.urlCorrigida === "true") return;

            let urlOriginal = link.href;
            let foiAlterado = false;

            // Só processa se a URL ainda não contiver o domínio de destino final
            if (!urlOriginal.includes(dominioDestino)) {
                dominiosOrigem.forEach(origem => {
                    // Verifica se a URL contém um dos domínios de origem e evita reprocessar o destino
                    if (urlOriginal.includes(origem) && origem !== dominioDestino) {
                        link.href = urlOriginal.replace(origem, dominioDestino);
                        foiAlterado = true;
                    }
                });
            }

            if (foiAlterado) {
                console.debug(`♻️ URL corrigida: ${urlOriginal} -> ${link.href}`);
                // Aplica o marcador no dataset do elemento DOM
                link.dataset.urlCorrigida = "true";
            }
        });
    }

    function verificarPagina() {
        const url = new URL(window.location.href);
        const params = url.searchParams;

        // Verifica se é Painel de Controle E se é o portlet de Journal
        const ehPainelControle = url.pathname.includes('control_panel');
        const ehJournalPortlet = params.get('p_p_id') === journalPortletId;

        if (ehPainelControle && ehJournalPortlet) {
            console.debug("📍 Contexto Journal detectado. Monitorando links...");
            ajustarUrlsNoticias();
        }
    }

    if (window.Liferay) {
        // Suporte para navegação SPA do Liferay
        Liferay.on('endNavigate', verificarPagina);

        // Delegar ao clique no body para capturar dropdowns gerados dinamicamente
        document.body.addEventListener('click', () => {
            // Timeout de 150ms para aguardar a renderização do menu pelo Clay UI
            setTimeout(ajustarUrlsNoticias, 150);
        });
    }

    // Execução imediata ao carregar o script
    verificarPagina();
})();
